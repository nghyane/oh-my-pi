{
	"name": "@nghyane/pi-codemode",
	"version": "12.18.4",
	"description": "Code Mode: convert tool-calling into TypeScript code generation for LLM orchestration",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		}
	},
	"files": [
		"src",
		"README.md"
	],
	"scripts": {
		"check": "tsgo -p tsconfig.json",
		"test": "bun test"
	},
	"dependencies": {
		"@nghyane/pi-agent-core": "^12.18.4",
		"@nghyane/pi-utils": "^12.18.4",
		"@sinclair/typebox": "^0.34.48"
	},
	"devDependencies": {
		"@types/bun": "^1.3.9"
	},
	"keywords": [
		"codemode",
		"ai",
		"llm",
		"tool-calling",
		"code-generation"
	],
	"author": "Can Bölük",
	"license": "GPL-3.0-or-later",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/can1357/oh-my-pi.git",
		"directory": "packages/codemode"
	},
	"homepage": "https://github.com/can1357/oh-my-pi",
	"bugs": {
		"url": "https://github.com/can1357/oh-my-pi/issues"
	},
	"engines": {
		"bun": ">=1.3.7"
	}
}
